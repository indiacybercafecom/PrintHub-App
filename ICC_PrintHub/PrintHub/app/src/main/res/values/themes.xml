<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PrintHub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/light_accent</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/divider</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/primary</item>

        <!-- Status and background colors. -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/light_accent</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Edge-to-Edge Support -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>

        <!-- Customizations -->
        <item name="dividerColor">@color/divider</item>
    </style>

    <style name="Theme.PrintHub" parent="Base.Theme.PrintHub" />

    <!-- Button Styles -->
    <style name="Widget.PrintHub.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.PrintHub.SmallComponent</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.PrintHub.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="ShapeAppearance.PrintHub.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.PrintHub</item>
        <item name="windowSplashScreenBackground">@color/white</item>
    </style>
</resources>