<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/light_accent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp" />

                <!-- Profile Photo Edit Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnEditProfilePhoto"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/white"
                    app:strokeWidth="2dp"
                    app:rippleColor="#40FFFFFF"
                    app:layout_constraintBottom_toBottomOf="@id/ivProfilePhoto"
                    app:layout_constraintEnd_toEndOf="@id/ivProfilePhoto"
                    android:layout_marginBottom="-4dp"
                    android:layout_marginEnd="-4dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/edit"
                        app:tint="@color/white"
                        android:contentDescription="Edit Profile Photo" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Sanjay Kumar Vaishya"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivProfilePhoto"
                    app:layout_constraintTop_toTopOf="@id/ivProfilePhoto" />

                <TextView
                    android:id="@+id/tvMobile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+91 6232421011"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tvFullName"
                    app:layout_constraintTop_toBottomOf="@id/tvFullName" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="sanjay@gmail.com"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tvFullName"
                    app:layout_constraintTop_toBottomOf="@id/tvMobile" />

                <TextView
                    android:id="@+id/tvMemberSince"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_pill_accent"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Member Since Jun 2026"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toStartOf="@id/tvFullName"
                    app:layout_constraintTop_toBottomOf="@id/tvEmail" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Menu Options -->
        <include
            android:id="@+id/menuManageAccount"
            layout="@layout/item_profile_option" />

        <include
            android:id="@+id/menuMyOrders"
            layout="@layout/item_profile_option" />

        <include
            android:id="@+id/menuSavedAddresses"
            layout="@layout/item_profile_option" />

        <include
            android:id="@+id/menuVouchers"
            layout="@layout/item_profile_option" />

        <include
            android:id="@+id/menuRatings"
            layout="@layout/item_profile_option" />

        <include
            android:id="@+id/menuLegal"
            layout="@layout/item_profile_option" />

        <!-- App Version Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvAppVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ICC PrintHub v1.0.1"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvBuildVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Build 2"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateCheck"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check for Updates"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/error_red"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
