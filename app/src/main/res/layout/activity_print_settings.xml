<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white"
            app:title="Print Settings"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomCard"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFileDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/secondary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File Analysis"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📄 File: "
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvFileType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📁 Type: "
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvFileSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📏 Size: "
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDetectedPages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📑 Actual Pages: Detecting..."
                        android:textColor="@color/primary"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="15sp"
                        android:layout_marginBottom="4dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/secondary"
                        android:layout_marginVertical="8dp"/>

                    <TextView
                        android:id="@+id/tvPrintType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🖨 Print Type: "
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCopiesSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋 Copies: 1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPricePerPage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💰 Price/Page: ₹0"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvTotalPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💵 Total: ₹0"
                        android:textColor="@color/primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color Mode"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgColorMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbBW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="Black &amp; White"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Color"
                    android:buttonTint="@color/primary" />

            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Paper Quality"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgPaperQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbLightBW"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Light BW (₹0.7/page)"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbMediumBW"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Medium BW (₹1/page)"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbHighBW"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="High BW (₹1.5/page)"
                    android:buttonTint="@color/primary" />

            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Copies"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="0dp"
                    android:text="-"
                    android:textSize="20sp"
                    app:cornerRadius="4dp"
                    app:strokeColor="@color/secondary"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tvCopies"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="0dp"
                    android:text="+"
                    android:textSize="20sp"
                    app:cornerRadius="4dp"
                    app:strokeColor="@color/secondary"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Binding"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgBinding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbLoose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Loose Paper (₹0)"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbStapled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stapled (₹15)"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbSpiral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spiral (₹40)"
                    android:buttonTint="@color/primary" />

            </RadioGroup>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estimated Price:"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.0"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/primary"
                    android:textSize="18sp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Print Set"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>